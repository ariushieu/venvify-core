# ==========================================================
# venvify-core — production env (VPS)
# cp .env.example .env rồi điền giá trị thật. KHÔNG commit .env.
# ==========================================================

# --- MySQL (chỉ khởi tạo /opt/data/venvify-core/mysql ở lần start ĐẦU TIÊN) ---
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=venvify_db
MYSQL_USER=venvify
MYSQL_PASSWORD=

# --- Spring datasource (host `mysql` = tên service trong docker-compose) ---
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/venvify_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
# App đọc thẳng MYSQL_USER / MYSQL_PASSWORD ở trên (application.yaml).

# --- JWT (>= 32 bytes; sinh bằng: openssl rand -hex 32) ---
SECRET_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- App URLs ---
# Base URL công khai của API (dựng link xác thực email) — domain thật + /api/v1
APP_BASE_URL=https://api.your-domain.com/api/v1
# CSV các origin FE được phép gọi API
APP_CORS_ALLOWED_ORIGINS=https://your-fe-domain.com

# --- Timezone (khớp Step 12 của setup_vps.sh) ---
TZ=Asia/Ho_Chi_Minh
MYSQL_TZ_OFFSET=+07:00
